# images/github-runner/Containerfile
#
# Extends the base Ubuntu 24.04 containerdisk used by pool.yaml to include
# the GitHub Actions runner agent and its dependencies. The resulting image
# is a KubeVirt containerdisk: a container whose sole purpose is to carry
# a qcow2 virtual-machine disk at /disk/.
#
# The runner agent is NOT started here — it is configured and launched at
# boot by a systemd service that polls for runner annotations set by the
# webhook server (blip.io/runner-token, blip.io/runner-url, blip.io/runner-labels).
#
# Build:
#   podman build --build-arg RUNNER_VERSION=2.321.0 \
#       -t <registry>/blip-github-runner:latest \
#       -f images/github-runner/Containerfile .
#
# After building, update pool.yaml to use this image:
#   source:
#     registry:
#       url: docker://<registry>/blip-github-runner:latest

# Pin the runner version for reproducible builds. Override at build time with:
#   --build-arg RUNNER_VERSION=x.y.z
ARG RUNNER_VERSION=2.321.0

# ---------------------------------------------------------------------------
# Stage 0: Import the base containerdisk as a named stage so the reference
#          is explicit and pinnable.
# ---------------------------------------------------------------------------
FROM quay.io/containerdisks/ubuntu:24.04 AS basedisk

# ---------------------------------------------------------------------------
# Stage 1: Download the GitHub Actions runner tarball AND pre-download all
#          .deb packages we need for the guest. The libguestfs appliance has
#          no network, so we download everything here where we have full
#          network access, then --copy-in the debs to the guest.
# ---------------------------------------------------------------------------
FROM docker.io/library/ubuntu:24.04 AS download

ARG RUNNER_VERSION

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Download the GitHub Actions runner tarball.
RUN curl -fsSL -o /tmp/actions-runner.tar.gz \
    "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-x64-${RUNNER_VERSION}.tar.gz"

# Download all .deb packages (and their transitive dependencies) for the
# guest. We use apt-get install --download-only which resolves dependencies
# and caches all .deb files, then copy them out.
#
# Package list rationale — only essentials for the runner agent. Heavy
# toolchains (docker, build-essential, nodejs, etc.) are left to workflows
# to install via actions/setup-* or apt-get at runtime.
RUN mkdir -p /debs && \
    apt-get update && \
    apt-get install -y --download-only --no-install-recommends \
        ca-certificates curl wget git jq unzip zip gnupg \
        sudo openssh-server iproute2 iputils-ping dnsutils \
        acl xz-utils zstd tar locales && \
    cp /var/cache/apt/archives/*.deb /debs/ && \
    echo "Downloaded $(ls /debs/*.deb | wc -l) packages with dependencies"

# ---------------------------------------------------------------------------
# Stage 2: Customise the qcow2 disk image using libguestfs.
# ---------------------------------------------------------------------------
FROM docker.io/library/ubuntu:24.04 AS customize

ARG RUNNER_VERSION

# Install libguestfs tools for qcow2 modification. linux-image-virtual is
# smaller than linux-image-generic and sufficient for the libguestfs appliance.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libguestfs-tools \
        linux-image-virtual \
        qemu-utils \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy the base containerdisk's qcow2 image from the named stage.
COPY --from=basedisk /disk/* /work/

# Identify the disk image file and rename it to a predictable name.
# Fail the build immediately if no disk image is found.
RUN DISK=$(find /work -maxdepth 1 -type f \( -name '*.qcow2' -o -name '*.img' \) | head -1) && \
    [ -n "$DISK" ] && \
    mv "$DISK" /work/disk.qcow2

# The qcow2 disk may be too small for all the packages we need. Grow it.
# qemu-img resize only expands the block device; virt-resize also grows the
# partition table and filesystem inside, which is what we actually need.
RUN export LIBGUESTFS_BACKEND=direct && \
    qemu-img create -f qcow2 /work/disk-expanded.qcow2 8G && \
    virt-resize --expand /dev/sda1 /work/disk.qcow2 /work/disk-expanded.qcow2 && \
    mv /work/disk-expanded.qcow2 /work/disk.qcow2

# Copy the pre-downloaded runner tarball and .deb packages from the download stage.
COPY --from=download /tmp/actions-runner.tar.gz /work/actions-runner.tar.gz
COPY --from=download /debs/ /work/debs/

# Write the setup script. This runs inside the guest via virt-customize.
# It handles ONLY offline operations: installing debs, extracting files,
# creating users, writing systemd units. No network is available.
COPY <<'SETUP' /work/setup.sh
#!/bin/sh
set -eu

export DEBIAN_FRONTEND=noninteractive

# --- Install pre-downloaded .deb packages ---
# Use dpkg to install all debs. Some may fail due to missing dependencies
# that are already on the base image, so we use --force-depends as a first
# pass, then fix up with dpkg --configure -a.
dpkg --force-depends -i /tmp/debs/*.deb || true
# Configure any half-installed packages (resolves dependency ordering).
dpkg --configure -a || true
# Verify critical packages are actually installed — these are required by
# the configure-runner script and the runner agent itself.
for pkg in curl jq git sudo; do
    dpkg -s "$pkg" >/dev/null 2>&1 || { echo "FATAL: required package $pkg not installed" >&2; exit 1; }
done
# Clean up the deb cache.
rm -rf /tmp/debs

# Generate locale (now that the locales package is installed).
locale-gen en_US.UTF-8 || true

# --- Extract the pre-downloaded GitHub Actions runner ---
RUNNER_DIR=/opt/actions-runner
mkdir -p "$RUNNER_DIR"
tar -xzf /tmp/actions-runner.tar.gz -C "$RUNNER_DIR"
rm -f /tmp/actions-runner.tar.gz

# --- Create runner user with docker group membership ---
# cloud-init also creates this user, but it handles pre-existing users
# gracefully (skips creation, applies policy only).
groupadd -f docker
useradd -m -s /bin/bash -u 1000 -G sudo,docker runner 2>/dev/null || true
chown -R 1000:1000 "$RUNNER_DIR"

# --- Write the runner bootstrap service ---
# The runner service is started explicitly by the setup service once
# configuration is complete. No [Install] section is needed because
# it is never auto-started by systemd on boot.
cat > /etc/systemd/system/github-runner.service <<'UNIT'
[Unit]
Description=GitHub Actions Runner
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User=runner
Group=runner
WorkingDirectory=/opt/actions-runner
Environment=RUNNER_ALLOW_RUNASROOT=0
ExecStart=/opt/actions-runner/run.sh
Restart=no
# Give the runner 15 minutes to finish a graceful shutdown.
TimeoutStopSec=900
UNIT

# --- Write the annotation poller that triggers runner configuration ---
# The webhook server writes runner config to VM annotations. This script
# polls the Kubernetes API (via the mounted service account) to read those
# annotations and configure the runner just-in-time.
cat > /usr/local/bin/configure-runner <<'POLLER'
#!/bin/bash
set -euo pipefail

readonly SA_DIR="/var/run/secrets/kubernetes.io/serviceaccount"
readonly RUNNER_DIR="/opt/actions-runner"
readonly MARKER="/var/run/blip/runner-configured"

echo "[runner-setup] waiting for runner annotations..."

token=""
runner_url=""
runner_labels=""

# Poll until the webhook server has patched the runner annotations.
# 360 iterations x 5s sleep = 30 minutes max wait.
for i in $(seq 1 360); do
    # Re-read the token each iteration to handle rotation.
    sa_token="$(cat "$SA_DIR/token")"
    ns="$(cat "$SA_DIR/namespace")"
    ca="$SA_DIR/ca.crt"
    vm_name="$(hostname)"
    api_url="https://kubernetes.default.svc/apis/kubevirt.io/v1/namespaces/${ns}/virtualmachines/${vm_name}"

    body=$(curl --silent --connect-timeout 5 --max-time 10 --cacert "$ca" \
        -H "Authorization: Bearer ${sa_token}" \
        "$api_url" 2>/dev/null) || { sleep 5; continue; }

    # Use jq for reliable JSON parsing (installed in the guest).
    token=$(printf '%s' "$body" | jq -r '.metadata.annotations["blip.io/runner-token"] // empty') || true
    runner_url=$(printf '%s' "$body" | jq -r '.metadata.annotations["blip.io/runner-url"] // empty') || true
    runner_labels=$(printf '%s' "$body" | jq -r '.metadata.annotations["blip.io/runner-labels"] // empty') || true

    if [ -n "$token" ] && [ -n "$runner_url" ]; then
        echo "[runner-setup] received runner config for $runner_url"
        break
    fi

    sleep 5
done

if [ -z "$token" ] || [ -z "$runner_url" ]; then
    echo "[runner-setup] FATAL: timed out waiting for runner annotations (30 min)" >&2
    exit 1
fi

# Configure the runner with --ephemeral so it de-registers after one job.
# Use --disableupdate to prevent the runner from self-updating (the image
# pins a known-good version).
cd "$RUNNER_DIR"

# Build label arguments safely using an array to avoid word-splitting issues.
label_args=()
if [ -n "$runner_labels" ]; then
    label_args=(--labels "$runner_labels")
fi

sudo -u runner ./config.sh \
    --url "$runner_url" \
    --token "$token" \
    --name "$(hostname)" \
    --work _work \
    --ephemeral \
    --disableupdate \
    --unattended \
    "${label_args[@]}" \
    --replace

echo "[runner-setup] runner configured, starting service"

# Signal that configuration is done and start the runner.
mkdir -p /var/run/blip
touch "$MARKER"
systemctl start github-runner.service

echo "[runner-setup] github-runner.service started"
POLLER
chmod 755 /usr/local/bin/configure-runner

# --- Write the systemd service that runs the annotation poller ---
# Depends on cloud-final.service because cloud-init mounts the service
# account at /var/run/secrets/kubernetes.io/serviceaccount which the
# poller needs to authenticate with the Kubernetes API. Uses Wants=
# (soft dependency) instead of Requires= so the service can still
# start if cloud-init is disabled on a subsequent boot.
cat > /etc/systemd/system/runner-setup.service <<'SETUP_UNIT'
[Unit]
Description=GitHub Actions Runner Setup (annotation poller)
After=network-online.target cloud-final.service
Wants=network-online.target cloud-final.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/configure-runner
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
SETUP_UNIT

# Enable the setup service so it runs on boot.
# systemctl enable works offline by creating symlinks.
ln -sf /etc/systemd/system/runner-setup.service \
    /etc/systemd/system/multi-user.target.wants/runner-setup.service

# --- Clean up ---
rm -rf /tmp/* /var/tmp/*
SETUP

# Customise the guest disk image. virt-customize launches a libguestfs
# appliance (a mini QEMU VM) that mounts the guest filesystem. The appliance
# has NO network access, so all packages are pre-downloaded and copied in
# as .deb files for offline installation.
#
# LIBGUESTFS_BACKEND=direct avoids the need for KVM inside the build container.
RUN export LIBGUESTFS_BACKEND=direct && \
    virt-customize \
        -a /work/disk.qcow2 \
        --copy-in /work/debs:/tmp \
        --copy-in /work/actions-runner.tar.gz:/tmp \
        --run /work/setup.sh

# ---------------------------------------------------------------------------
# Stage 3: Package the customised disk as a containerdisk.
# ---------------------------------------------------------------------------
FROM scratch

LABEL org.opencontainers.image.description="KubeVirt containerdisk with GitHub Actions runner for Blip"
LABEL org.opencontainers.image.source="https://github.com/project-unbounded/blip"

# KubeVirt containerdisks expect the disk image at /disk/.
COPY --from=customize /work/disk.qcow2 /disk/disk.qcow2
