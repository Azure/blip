# images/base/Containerfile
#
# KubeVirt containerdisk: Ubuntu 24.04 cloud image with neovim, opencode, and Go.
# Downloads the official Ubuntu cloud image and customises it with virt-customize.
#
# Build:
#   docker build -t <registry>/blip-base:latest -f images/base/Containerfile .

FROM docker.io/library/ubuntu:24.04 AS build

RUN apt-get update && apt-get install -y --no-install-recommends \
        libguestfs-tools linux-image-virtual qemu-utils \
        ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /work

# Download official Ubuntu 24.04 cloud image.
RUN curl -fsSL -o /work/disk.qcow2 \
    "https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"

# Pre-download Go and opencode binary (guest has no network).
ARG GO_VERSION=1.24.2
RUN curl -fsSL -o /work/go.tar.gz \
        "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" && \
    curl -fsSL -o /work/install-opencode.sh \
        "https://opencode.ai/install" && \
    curl -fsSL -L -o /work/opencode.tar.gz \
        "https://github.com/anomalyco/opencode/releases/latest/download/opencode-linux-x64.tar.gz"

# Pre-download GitHub Actions runner.
ARG RUNNER_VERSION=2.321.0
RUN curl -fsSL -L -o /work/actions-runner.tar.gz \
        "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-x64-${RUNNER_VERSION}.tar.gz"

# Expand the disk so there is room to install packages, then customise.
# We use virt-resize to grow sda1 and its filesystem in one step.
RUN export LIBGUESTFS_BACKEND=direct && \
    qemu-img create -f qcow2 /work/disk-big.qcow2 16G && \
    virt-resize --expand /dev/sda1 /work/disk.qcow2 /work/disk-big.qcow2 && \
    mv /work/disk-big.qcow2 /work/disk.qcow2

# Download neovim .deb packages for offline install into the guest.
RUN mkdir -p /work/debs && \
    apt-get update && \
    apt-get install -y --download-only --no-install-recommends neovim && \
    cp /var/cache/apt/archives/*.deb /work/debs/ && \
    rm -rf /var/lib/apt/lists/*

# Write a setup script that runs inside the guest (no network).
COPY <<'SETUP' /work/setup.sh
#!/bin/bash
set -eu
export DEBIAN_FRONTEND=noninteractive

# Install neovim from pre-downloaded debs.
dpkg --force-depends -i /tmp/debs/*.deb || true
dpkg --configure -a || true
rm -rf /tmp/debs

# Install Go.
tar -C /usr/local -xzf /tmp/go.tar.gz && rm /tmp/go.tar.gz
cat > /etc/profile.d/golang.sh <<'EOF'
export PATH="/usr/local/go/bin:$PATH"
EOF

# Install opencode using the install script with --binary flag.
bash /tmp/install-opencode.sh --binary /tmp/opencode --no-modify-path
ln -sf /root/.opencode/bin/opencode /usr/local/bin/opencode
rm -f /tmp/opencode /tmp/install-opencode.sh /tmp/opencode.tar.gz

# Install GitHub Actions runner.
useradd -m -s /bin/bash runner
mkdir -p /home/runner/actions-runner
tar -xzf /tmp/actions-runner.tar.gz -C /home/runner/actions-runner
rm -f /tmp/actions-runner.tar.gz
/home/runner/actions-runner/bin/installdependencies.sh
chown -R runner:runner /home/runner/actions-runner
SETUP

RUN export LIBGUESTFS_BACKEND=direct && \
    virt-customize -a /work/disk.qcow2 \
        --copy-in /work/debs:/tmp \
        --copy-in /work/go.tar.gz:/tmp \
        --copy-in /work/install-opencode.sh:/tmp \
        --copy-in /work/opencode.tar.gz:/tmp \
        --copy-in /work/actions-runner.tar.gz:/tmp \
        --run-command 'tar -xzf /tmp/opencode.tar.gz -C /tmp && rm /tmp/opencode.tar.gz' \
        --run /work/setup.sh

# ---------------------------------------------------------------------------
# Final: package as a containerdisk (disk image at /disk/).
# ---------------------------------------------------------------------------
FROM scratch
LABEL org.opencontainers.image.description="KubeVirt containerdisk: Ubuntu 24.04 with neovim, opencode, Go, and GitHub Actions runner"
COPY --from=build /work/disk.qcow2 /disk/disk.qcow2
